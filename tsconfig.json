{
  "compilerOptions": {
    "lib": ["ESNext"],
    "module": "ESNext",
    "target": "ESNext",
    "moduleResolution": "bundler",
    "types": ["bun"],
    "allowImportingTsExtensions": true,
    "verbatimModuleSyntax": true,
    "noEmit": true,
    "strict": true,
    "skipLibCheck": true,
    "forceConsistentCasingInFileNames": true
  },
  "include": ["src", "test", "bench"],
  "comment": "bench/corpus and bench/fixtures* hold vendored source and generated single-file fixtures (dangling imports by design) — they are benchmark data, not project source.",
  "exclude": ["bench/corpus", "bench/fixtures", "bench/fixtures-holdout"]
}
